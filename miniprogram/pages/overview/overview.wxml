<!--pages/overview/overview.wxml - 小屋手账（功能中枢）-->
<nav-back />

<view class="page-loading" wx:if="{{loading}}">手账翻开中…</view>

<view class="overview" wx:else style="padding-top: {{safeTop + 70}}px">
  <!-- 天数 -->
  <view class="days card">
    <image class="days-title" src="/assets/title.png" mode="widthFix" />
    <view class="days-line">
      <text>一起在小屋的第</text>
      <text class="days-num">{{days}}</text>
      <text>天</text>
      <image class="days-heart" src="/assets/heart.png" mode="widthFix" />
    </view>
  </view>

  <!-- 功能模块 -->
  <view class="modules">
    <view
      wx:for="{{modules}}"
      wx:key="key"
      class="module card"
      hover-class="btn-pressed"
      data-url="{{item.url}}"
      data-title="{{item.title}}"
      bindtap="onTapModule"
    >
      <view class="module-badge" wx:if="{{item.badge > 0}}">{{item.badge}}</view>
      <image class="module-icon" src="{{item.icon}}" mode="aspectFit" />
      <text class="module-title">{{item.title}}</text>
      <text class="module-desc">{{item.desc}}</text>
    </view>
  </view>
</view>

<paper-toast id="toast" />
