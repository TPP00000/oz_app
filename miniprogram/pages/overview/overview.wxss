/* pages/overview/overview.wxss */
.overview {
  padding: 0 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

/* 天数 */
.days {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 36rpx;
}

.days-title {
  width: 220rpx;
}

.days-line {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  font-size: 27rpx;
  color: var(--color-ink);
}

.days-num {
  font-size: 52rpx;
  color: var(--color-primary-deep);
}

.days-heart {
  width: 34rpx;
  align-self: center;
}

/* 功能模块九宫格 */
.modules {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx;
}

.module {
  position: relative;
  flex: 1 1 40%;
  min-width: 40%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 34rpx 20rpx 28rpx;
}

.module-icon {
  width: 96rpx;
  height: 96rpx;
}

.module-title {
  font-size: 29rpx;
  color: var(--color-ink);
}

.module-desc {
  font-size: 22rpx;
  color: var(--color-ink-soft);
  text-align: center;
}

.module-badge {
  position: absolute;
  top: 14rpx;
  right: 16rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: var(--color-gold);
  color: #fff;
  font-size: 21rpx;
  line-height: 34rpx;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(200, 145, 42, 0.4);
}
