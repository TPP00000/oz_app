<!--pages/photos/photos.wxml - 照片墙-->
<image class="page-bg" src="/assets/card-paper.jpg" mode="aspectFill" />
<nav-back />

<view class="page-loading" wx:if="{{loading}}">照片墙擦拭中…</view>

<view class="photos-page" wx:else style="padding-top: {{safeTop + 60}}px">
  <view class="refresh-tip" wx:if="{{refreshing}}">
    <view class="spinner"></view>
  </view>

  <view class="head">
    <text class="head-title">我们的日常</text>
    <text class="head-sub" wx:if="{{total > 0}}">已经贴了 {{total}} 张</text>
  </view>

  <!-- 拍立得双列墙 -->
  <view class="wall" wx:if="{{total > 0}}">
    <view class="col">
      <view
        wx:for="{{leftCol}}"
        wx:key="id"
        class="polaroid"
        style="transform: rotate({{item.tilt}}deg)"
        data-fileid="{{item.fileId}}"
        data-id="{{item.id}}"
        data-mine="{{item.mine}}"
        bindtap="onPreview"
        bindlongpress="onLongPress"
      >
        <image class="polaroid-img" src="{{item.fileId}}" mode="aspectFill" />
        <text class="polaroid-caption" wx:if="{{item.caption}}">{{item.caption}}</text>
        <view class="polaroid-meta">
          <text class="meta-who {{item.mine ? 'who-me' : 'who-ta'}}">{{item.who}}</text>
          <text class="meta-date">{{item.date}}</text>
        </view>
      </view>
    </view>
    <view class="col">
      <view
        wx:for="{{rightCol}}"
        wx:key="id"
        class="polaroid"
        style="transform: rotate({{item.tilt}}deg)"
        data-fileid="{{item.fileId}}"
        data-id="{{item.id}}"
        data-mine="{{item.mine}}"
        bindtap="onPreview"
        bindlongpress="onLongPress"
      >
        <image class="polaroid-img" src="{{item.fileId}}" mode="aspectFill" />
        <text class="polaroid-caption" wx:if="{{item.caption}}">{{item.caption}}</text>
        <view class="polaroid-meta">
          <text class="meta-who {{item.mine ? 'who-me' : 'who-ta'}}">{{item.who}}</text>
          <text class="meta-date">{{item.date}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:if="{{total === 0}}">
    <image class="empty-heart" src="/assets/heart.png" mode="widthFix" />
    <text>墙上还空空的～</text>
    <text>贴下第一张日常吧</text>
  </view>
</view>

<!-- 贴一张 -->
<view
  class="btn-primary add-btn {{uploading ? 'disabled' : ''}}"
  hover-class="btn-pressed"
  bindtap="onAddPhoto"
  wx:if="{{!loading}}"
>{{uploading ? '张贴中…' : '📷 贴一张'}}</view>

<paper-toast id="toast" />
