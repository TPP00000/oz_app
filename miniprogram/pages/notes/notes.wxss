/* pages/notes/notes.wxss */
.page-bg {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
}

.notes-page {
  padding: 0 36rpx 180rpx;
}

.head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 30rpx;
}

.head-title {
  font-size: 40rpx;
  color: var(--color-ink);
  letter-spacing: 4rpx;
}

.head-sub {
  font-size: 23rpx;
  color: var(--color-ink-soft);
}

/* 纸条双列 */
.wall {
  display: flex;
  gap: 26rpx;
  align-items: flex-start;
}

.col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 34rpx;
}

.note {
  position: relative;
  background: #fffdf6;
  border: 2rpx solid rgba(150, 110, 70, 0.18);
  border-radius: 6rpx;
  padding: 26rpx 14rpx 12rpx;
  box-shadow: 0 10rpx 24rpx rgba(120, 85, 50, 0.16);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 图钉 */
.pin {
  position: absolute;
  top: 10rpx;
  left: 50%;
  margin-left: -9rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%, #f6a9b8, #c25e75);
  box-shadow: 0 3rpx 5rpx rgba(90, 40, 40, 0.4);
}

.note-img {
  width: 100%;
}

.note-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meta-who {
  font-size: 20rpx;
  padding: 2rpx 14rpx;
  border-radius: 14rpx;
}

.who-me {
  background: #eaf0dd;
  color: #6e8a4e;
}

.who-ta {
  background: #f8dfe4;
  color: #c25e75;
}

.meta-date {
  font-size: 20rpx;
  color: var(--color-ink-soft);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-top: 140rpx;
  color: var(--color-ink-soft);
  font-size: 26rpx;
}

.empty-heart {
  width: 70rpx;
  margin-bottom: 8rpx;
}

/* 写一张：右下角悬浮 */
.write-btn {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  z-index: 50;
  padding: 20rpx 44rpx;
}
