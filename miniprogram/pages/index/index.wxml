<!--pages/index/index.wxml - 茄茄小屋主页（横向全景房间）-->
<view class="page-loading" wx:if="{{loading}}">小屋开门中…</view>

<view class="page-loading" wx:elif="{{loadFailed}}">
  <view class="retry-box">
    <text>小屋暂时打不开</text>
    <view class="btn-ghost retry-btn" hover-class="btn-pressed" bindtap="onRetry">再试一次</view>
  </view>
</view>

<view class="home" wx:else>
  <scroll-view
    class="pano-scroll"
    scroll-x="{{true}}"
    enhanced="{{true}}"
    bounces="{{false}}"
    fast-deceleration="{{false}}"
    show-scrollbar="{{false}}"
    scroll-left="{{scrollLeft}}"
  >
    <view class="pano" style="width: {{panoWidth}}px; height: {{panoHeight}}px;">
      <image class="pano-img" src="/assets/room-pano-empty.jpg" />

      <!-- 占位物件（未精灵化）：按下柔光缓缓浮现 -->
      <view
        wx:for="{{placeholders}}"
        wx:key="key"
        class="hotspot"
        hover-class="hotspot-hover"
        hover-stay-time="250"
        style="left: {{item.left}}%; top: {{item.top}}%; width: {{item.width}}%; height: {{item.height}}%;"
        data-name="{{item.name}}"
        bindtap="onTapPlaceholder"
      >
        <view class="glow"></view>
      </view>

      <!-- 物件精灵：静止时与背景逐像素还原，按下时呼吸缩放 + 轮廓光晕 -->
      <view
        wx:for="{{sprites}}"
        wx:key="key"
        class="hotspot"
        hover-class="sprite-pressed"
        hover-stay-time="250"
        style="left: {{item.left}}%; top: {{item.top}}%; width: {{item.width}}%; height: {{item.height}}%;"
        data-key="{{item.key}}"
        data-name="{{item.name}}"
        data-url="{{item.url || ''}}"
        bindtap="onTapPlaceholder"
      >
        <image
          class="obj-sprite"
          src="/assets/{{item.src}}"
          mode="scaleToFill"
          style="left: {{item.img.left}}%; top: {{item.img.top}}%; width: {{item.img.width}}%; height: {{item.img.height}}%;"
        />
      </view>

      <!-- 茄子造型/双人姿势叠加层 -->
      <image
        wx:for="{{overlays}}"
        wx:key="key"
        class="avatar-overlay"
        src="{{item.src}}"
        mode="scaleToFill"
        style="left: {{item.rect.left}}%; top: {{item.rect.top}}%; width: {{item.rect.width}}%; height: {{item.rect.height}}%;"
      />
      <!-- 合体状态的点击热区 -->
      <view
        wx:if="{{duoRect}}"
        class="hotspot duo-hotspot"
        hover-class="sprite-pressed"
        hover-stay-time="250"
        style="left: {{duoRect.left}}%; top: {{duoRect.top}}%; width: {{duoRect.width}}%; height: {{duoRect.height}}%;"
        bindtap="onTapDuo"
      ></view>

      <!-- 愿望树精灵：点击进入愿望树页 -->
      <view
        class="hotspot tree-hotspot"
        hover-class="sprite-pressed"
        hover-stay-time="250"
        style="left: {{treeRect.left}}%; top: {{treeRect.top}}%; width: {{treeRect.width}}%; height: {{treeRect.height}}%;"
        bindtap="goTree"
      >
        <image
          class="obj-sprite"
          src="/assets/sp-tree.png"
          mode="scaleToFill"
          style="left: {{treeImg.left}}%; top: {{treeImg.top}}%; width: {{treeImg.width}}%; height: {{treeImg.height}}%;"
        />
      </view>
    </view>
  </scroll-view>

  <view class="refresh-tip" wx:if="{{refreshing}}">
    <view class="spinner"></view>
  </view>

  <!-- 木牌：点击进入小屋手账（总览页） -->
  <view
    class="header-board"
    style="top: {{chipTop}}px"
    hover-class="board-pressed"
    hover-stay-time="150"
    bindtap="goOverview"
  >
    <image class="board-bg" src="/assets/board.png" mode="widthFix" />
    <view class="board-content">
      <image class="title-img" src="/assets/title.png" mode="widthFix" />
      <view class="subtitle">
        <text>一起在小屋的第 {{daysTogether}} 天</text>
        <image class="heart-icon" src="/assets/heart.png" mode="widthFix" />
      </view>
    </view>
    <view class="board-dot" wx:if="{{pendingForMe > 0}}">{{pendingForMe}}</view>
  </view>

  <!-- 角色选择 -->
  <view class="mask" wx:if="{{rolePick}}" bindtap="onCloseRolePick">
    <view class="role-card card" catchtap="">
      <text class="role-title">你是哪只茄子？</text>
      <text class="role-sub">选定后就是你在小屋里的分身啦</text>
      <view class="role-row">
        <view
          class="role-option {{roleTaken === 'king' ? 'role-disabled' : ''}}"
          hover-class="btn-pressed"
          data-role="king"
          bindtap="onChooseRole"
        >
          <image class="role-img" src="{{portraitKing}}" mode="aspectFit" />
          <text>茄子王</text>
          <text class="role-taken" wx:if="{{roleTaken === 'king'}}">TA 已选</text>
        </view>
        <view
          class="role-option {{roleTaken === 'small' ? 'role-disabled' : ''}}"
          hover-class="btn-pressed"
          data-role="small"
          bindtap="onChooseRole"
        >
          <image class="role-img" src="{{portraitSmall}}" mode="aspectFit" />
          <text>小茄子</text>
          <text class="role-taken" wx:if="{{roleTaken === 'small'}}">TA 已选</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 造型/互动面板 -->
  <view class="mask" wx:if="{{panel}}" bindtap="onClosePanel">
    <view class="panel card" catchtap="">
      <text class="panel-title">{{panel.title}}</text>
      <view class="panel-options">
        <view
          wx:for="{{panel.options}}"
          wx:key="key"
          class="panel-option {{item.active ? 'panel-active' : ''}}"
          hover-class="btn-pressed"
          data-key="{{item.key}}"
          data-kind="{{item.kind || ''}}"
          bindtap="onPanelSelect"
        >{{item.label}}</view>
      </view>
      <view class="btn-ghost panel-cancel" hover-class="btn-pressed" bindtap="onClosePanel">先不了</view>
    </view>
  </view>
</view>

<paper-toast id="toast" />
