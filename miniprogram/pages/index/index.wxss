/* pages/index/index.wxss */
.home {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.pano-scroll {
  width: 100%;
  height: 100%;
  /* 兜底：越界空隙显示与全景图边缘取样一致的渐变（墙面→地板），肉眼无感 */
  background: linear-gradient(180deg, #C6A061 0%, #C6A061 35%, #9F7F44 55%, #7C5622 100%);
}

.home {
  background: linear-gradient(180deg, #C6A061 0%, #C6A061 35%, #9F7F44 55%, #7C5622 100%);
}

.pano {
  position: relative;
}

.pano-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* 热区：平时完全隐形 */
.hotspot {
  position: absolute;
}

/* 柔光层：椭圆渐变贴合物件轮廓，按下时缓缓浮现、松手缓缓消退 */
.glow {
  position: absolute;
  inset: -6%;
  background: radial-gradient(
    ellipse closest-side,
    rgba(255, 240, 200, 0.5),
    rgba(255, 240, 200, 0.22) 60%,
    rgba(255, 240, 200, 0) 100%
  );
  opacity: 0;
  transition: opacity 0.35s ease;
}

.glow-gold {
  background: radial-gradient(
    ellipse closest-side,
    rgba(255, 219, 140, 0.6),
    rgba(255, 219, 140, 0.28) 60%,
    rgba(255, 219, 140, 0) 100%
  );
}

.hotspot-hover .glow {
  opacity: 1;
}

/* 愿望树热区在其他家具热区之上 */
.tree-hotspot {
  z-index: 2;
}

/* 待回答角标：安静的小圆点，不做动画 */
.tree-dot {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: var(--color-gold);
  color: #fff;
  font-size: 22rpx;
  line-height: 36rpx;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(200, 145, 42, 0.4);
}

/* 标题浮层 */
/* 水彩木质挂牌标题（与插画同风格） */
.header-board {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  width: 460rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(120, 85, 50, 0.25));
}

.board-bg {
  width: 100%;
  display: block;
}

/* 内容对齐到木板板面区域（新板面上下基本对称，约纵向 18%~82%） */
.board-content {
  position: absolute;
  left: 13%;
  right: 13%;
  top: 18%;
  bottom: 18%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.title-img {
  width: 200rpx;
}

.subtitle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #6b4a32;
  letter-spacing: 1rpx;
}

.heart-icon {
  width: 30rpx;
}

.retry-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.retry-btn {
  padding: 12rpx 48rpx;
}
