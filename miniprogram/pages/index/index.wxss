/* pages/index/index.wxss */
.home {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.pano-scroll {
  width: 100%;
  height: 100%;
  /* 兜底：越界空隙显示与全景图边缘取样一致的渐变（墙面→地板），肉眼无感 */
  background: linear-gradient(180deg, #D6B788 0%, #D6B788 35%, #DCBF8F 55%, #96723D 100%);
}

.home {
  background: linear-gradient(180deg, #D6B788 0%, #D6B788 35%, #DCBF8F 55%, #96723D 100%);
}

.pano {
  position: relative;
}

.pano-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

/* 热区：平时完全隐形 */
.hotspot {
  position: absolute;
}

/* 柔光层：椭圆渐变贴合物件轮廓，按下时缓缓浮现、松手缓缓消退 */
.glow {
  position: absolute;
  inset: -6%;
  background: radial-gradient(
    ellipse closest-side,
    rgba(255, 240, 200, 0.5),
    rgba(255, 240, 200, 0.22) 60%,
    rgba(255, 240, 200, 0) 100%
  );
  opacity: 0;
  transition: opacity 0.35s ease;
}

.hotspot-hover .glow {
  opacity: 1;
}

/* 愿望树热区在其他物件精灵之上 */
.tree-hotspot {
  z-index: 2;
}

/* 物件精灵：从场景图中抠出的图层，静止时与背景逐像素重合
 * （位置尺寸由内联样式给出：图像含阴影，可超出热区，超出部分不可点击）*/
.obj-sprite {
  position: absolute;
  transform-origin: 50% 88%;
  transition: filter 0.25s ease;
}

/* 按住时物件呼吸缩放 + 贴合轮廓的金色光晕（由透明通道生成） */
.sprite-pressed .obj-sprite {
  animation: sprite-breathe 1.1s ease-in-out infinite;
  filter: drop-shadow(0 0 20rpx rgba(255, 214, 130, 0.95))
    drop-shadow(0 0 6rpx rgba(255, 226, 160, 0.8));
}

@keyframes sprite-breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.04);
  }
}

/* 待回答角标：安静地挂在木牌右上角 */
.board-dot {
  position: absolute;
  top: 16%;
  right: 8%;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: var(--color-gold);
  color: #fff;
  font-size: 22rpx;
  line-height: 36rpx;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(200, 145, 42, 0.4);
}

/* 标题浮层 */
/* 水彩木质挂牌标题（与插画同风格，可点击进入小屋手账） */
.header-board {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  width: 400rpx;
  filter: drop-shadow(0 8rpx 16rpx rgba(120, 85, 50, 0.25));
  transition: transform 0.12s ease;
}

.board-pressed {
  transform: translateX(-50%) translateY(4rpx) scale(0.98);
}

.board-bg {
  width: 100%;
  display: block;
}

/* 内容对齐到木板板面区域（新板面上下基本对称，约纵向 18%~82%） */
.board-content {
  position: absolute;
  left: 13%;
  right: 13%;
  top: 18%;
  bottom: 18%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.title-img {
  width: 176rpx;
}

.subtitle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 23rpx;
  font-weight: 600;
  color: #6b4a32;
  letter-spacing: 1rpx;
}

.heart-icon {
  width: 30rpx;
}

.retry-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.retry-btn {
  padding: 12rpx 48rpx;
}

/* ===== 茄子角色/造型/互动 ===== */
.avatar-overlay {
  position: absolute;
  z-index: 3;
  /* 贴图只负责显示，点击穿透给底下的茄子热区 */
  pointer-events: none;
}

.duo-hotspot {
  z-index: 4;
}

.mask {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(60, 42, 28, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 角色选择 */
.role-card {
  width: 590rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 44rpx 36rpx;
}

.role-title {
  font-size: 36rpx;
  color: var(--color-ink);
  letter-spacing: 4rpx;
}

.role-sub {
  font-size: 23rpx;
  color: var(--color-ink-soft);
}

.role-row {
  margin-top: 20rpx;
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.role-option {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 26rpx 0 20rpx;
  background: #fbedde;
  border: 3rpx solid var(--color-line);
  border-radius: 26rpx;
  font-size: 28rpx;
  color: var(--color-ink);
  box-shadow: 0 6rpx 0 rgba(170, 130, 90, 0.22),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.7);
}

.role-img {
  width: 120rpx;
  height: 140rpx;
}

.role-disabled {
  opacity: 0.45;
}

.role-taken {
  font-size: 20rpx;
  color: var(--color-primary-deep);
}

/* 造型/互动面板 */
.panel {
  width: 590rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 40rpx 36rpx;
}

.panel-title {
  text-align: center;
  font-size: 30rpx;
  color: var(--color-ink);
}

.panel-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.panel-option {
  flex: 1 1 40%;
  text-align: center;
  padding: 20rpx 0;
  background: #fbedde;
  border: 3rpx solid var(--color-line);
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--color-ink);
  box-shadow: 0 5rpx 0 rgba(170, 130, 90, 0.22),
    inset 0 3rpx 0 rgba(255, 255, 255, 0.7);
}

.panel-active {
  background: linear-gradient(135deg, #fbc29b, #f09372);
  border-color: rgba(150, 90, 55, 0.55);
  color: #fff;
  text-shadow: 0 2rpx 0 rgba(140, 80, 50, 0.3);
}

.panel-cancel {
  margin-top: 6rpx;
}
