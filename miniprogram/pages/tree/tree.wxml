<!--pages/tree/tree.wxml - 茄茄愿望树页-->
<view class="page-loading" wx:if="{{loading}}">愿望树生长中…</view>

<view class="tree-page" wx:else style="padding-top: {{safeTop + 60}}px">
  <nav-back />
  <view class="refresh-tip" wx:if="{{refreshing}}">
    <view class="spinner"></view>
  </view>
  <image class="page-bg" src="/assets/tree-bg-day.jpg" mode="aspectFill" />

  <!-- 成长树 -->
  <view class="scene">
    <image class="tree" src="{{treeSrc}}" mode="widthFix" />
    <view class="stage-chip">Lv.{{stage}} {{stageName}}</view>
    <text class="grow-text">{{growText}}</text>
  </view>

  <!-- 双方数据统计 -->
  <view class="stats card">
    <view class="stat-cell">
      <text class="stat-num">{{stats.askedByMe}}</text>
      <text class="stat-label">我提问</text>
    </view>
    <view class="stat-cell">
      <text class="stat-num">{{stats.answeredByMe}}</text>
      <text class="stat-label">我回答</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-cell">
      <text class="stat-num">{{stats.askedByTa}}</text>
      <text class="stat-label">TA 提问</text>
    </view>
    <view class="stat-cell">
      <text class="stat-num">{{stats.answeredByTa}}</text>
      <text class="stat-label">TA 回答</text>
    </view>
  </view>

  <view class="btn-primary plant-btn" hover-class="btn-pressed" bindtap="onPlant">🌱 种一个问题</view>

  <!-- 问答分类 -->
  <view class="tabs">
    <view
      class="tab {{activeTab === 'forMe' ? 'tab-active' : ''}}"
      data-tab="forMe"
      bindtap="onSwitchTab"
    >TA 问我的 ({{listForMe.length}})</view>
    <view
      class="tab {{activeTab === 'byMe' ? 'tab-active' : ''}}"
      data-tab="byMe"
      bindtap="onSwitchTab"
    >我问 TA 的 ({{listByMe.length}})</view>
  </view>

  <view class="list">
    <view
      wx:for="{{activeTab === 'forMe' ? listForMe : listByMe}}"
      wx:key="id"
      class="list-item card"
      hover-class="btn-pressed"
      data-id="{{item.id}}"
      bindtap="onTapCard"
    >
      <image class="list-icon" src="/assets/fruit-{{item.species}}.png" mode="widthFix" />
      <text class="list-q">{{item.question}}</text>
      <text class="list-tag tag-{{item.status}}">{{item.statusText}}</text>
    </view>

    <view class="empty" wx:if="{{(activeTab === 'forMe' ? listForMe : listByMe).length === 0}}">
      <text wx:if="{{activeTab === 'forMe'}}">TA 还没有问过你问题～</text>
      <text wx:else>你还没有问过 TA 问题，去种一个吧 🌱</text>
    </view>
  </view>
</view>

<paper-toast id="toast" />
