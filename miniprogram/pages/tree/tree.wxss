/* pages/tree/tree.wxss */
.tree-page {
  position: relative;
  min-height: 100vh;
  padding: 32rpx 40rpx 80rpx;
  box-sizing: border-box;
}

.page-bg {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
}

/* 成长树 */
.scene {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 8rpx;
}

.tree {
  width: 340rpx;
  filter: drop-shadow(0 10rpx 22rpx rgba(120, 90, 60, 0.22));
}

.stage-chip {
  margin-top: 12rpx;
  background: var(--color-paper);
  border: 3rpx solid var(--color-line);
  border-radius: 999rpx;
  padding: 8rpx 30rpx;
  font-size: 25rpx;
  color: var(--color-ink);
  box-shadow: 0 5rpx 0 rgba(170, 130, 90, 0.22),
    inset 0 3rpx 0 rgba(255, 255, 255, 0.8);
}

.grow-text {
  margin-top: 12rpx;
  font-size: 23rpx;
  color: var(--color-ink-soft);
}

/* 统计 */
.stats {
  margin-top: 26rpx;
  display: flex;
  align-items: center;
  padding: 26rpx 12rpx;
}

.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 40rpx;
  color: var(--color-primary-deep);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-ink-soft);
}

.stat-divider {
  width: 3rpx;
  height: 64rpx;
  background: var(--color-line);
}

.plant-btn {
  margin: 28rpx auto 0;
  width: 420rpx;
}

/* 分类页签 */
.tabs {
  display: flex;
  gap: 16rpx;
  margin: 34rpx 0 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--color-ink-soft);
  background: rgba(255, 251, 240, 0.6);
  border: 3rpx solid var(--color-line);
  border-radius: 999rpx;
}

.tab-active {
  background: linear-gradient(135deg, #fbc29b, #f09372);
  border-color: rgba(150, 90, 55, 0.55);
  color: #fff;
  text-shadow: 0 2rpx 0 rgba(140, 80, 50, 0.3);
  box-shadow: 0 5rpx 0 rgba(170, 110, 70, 0.35),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.4);
}

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 30rpx;
}

.list-icon {
  width: 46rpx;
  flex-shrink: 0;
}

.list-q {
  flex: 1;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-tag {
  flex-shrink: 0;
  font-size: 21rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.tag-pending {
  background: #f8e8c6;
  color: #9c6f2b;
}

.tag-done {
  background: #f8dfe4;
  color: #c25e75;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-top: 40rpx;
  color: var(--color-ink-soft);
  font-size: 26rpx;
}
