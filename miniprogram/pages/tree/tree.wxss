/* pages/tree/tree.wxss */
.tree-page {
  position: relative;
  min-height: 100vh;
  padding: 32rpx 40rpx 80rpx;
  box-sizing: border-box;
}

.page-bg {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
}

/* 成长树（唯一被滚出屏幕的内容） */
.scene {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 8rpx;
}

.tree {
  width: 300rpx;
  filter: drop-shadow(0 10rpx 22rpx rgba(120, 90, 60, 0.22));
}

.sticky-sentinel {
  height: 2rpx;
}

/* 吸顶头部：纯 CSS sticky，碰顶即锁，布局零变化 */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 90;
  margin: 0 -40rpx;
  overflow: hidden;
}

/* 遮挡帷幕：与页面固定背景同图同裁切，锁定时与底层背景逐像素重合 */
.header-veil {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.header-veil.veil-on {
  opacity: 1;
}

.header-inner {
  position: relative;
  padding: 0 40rpx 18rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 档位牌行：与微信胶囊同高对齐（间距由内联样式给出） */
.chip-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.stage-chip {
  background: var(--color-paper);
  border: 3rpx solid var(--color-line);
  border-radius: 999rpx;
  padding: 6rpx 30rpx;
  font-size: 25rpx;
  color: var(--color-ink);
  box-shadow: 0 5rpx 0 rgba(170, 130, 90, 0.22),
    inset 0 3rpx 0 rgba(255, 255, 255, 0.8);
}

.grow-text {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: var(--color-ink-soft);
}

/* 统计 */
.stats {
  width: 100%;
  box-sizing: border-box;
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  padding: 26rpx 12rpx;
}

.stat-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 40rpx;
  color: var(--color-primary-deep);
}

.stat-label {
  font-size: 22rpx;
  color: var(--color-ink-soft);
}

.stat-divider {
  width: 3rpx;
  height: 64rpx;
  background: var(--color-line);
}

/* 页签 + 提问按钮一行 */
.action-row {
  width: 100%;
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
  align-items: stretch;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 25rpx;
  color: var(--color-ink-soft);
  background: var(--color-paper);
  border: 3rpx solid var(--color-line);
  border-radius: 999rpx;
  box-shadow: 0 5rpx 0 rgba(170, 130, 90, 0.22),
    inset 0 3rpx 0 rgba(255, 255, 255, 0.7);
}

.plant-mini {
  flex-shrink: 0;
  width: 170rpx;
  padding: 16rpx 0;
  font-size: 25rpx;
}

.tab-active {
  background: linear-gradient(135deg, #fbc29b, #f09372);
  border-color: rgba(150, 90, 55, 0.55);
  color: #fff;
  text-shadow: 0 2rpx 0 rgba(140, 80, 50, 0.3);
  box-shadow: 0 5rpx 0 rgba(170, 110, 70, 0.35),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.4);
}

/* 列表：最小高度由 JS 精确计算（屏高-头部高），切页签滚动不动、短内容不过滚 */
.list {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 30rpx;
}

.list-icon {
  width: 46rpx;
  flex-shrink: 0;
}

.list-q {
  flex: 1;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-tag {
  flex-shrink: 0;
  font-size: 21rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.tag-pending {
  background: #f8e8c6;
  color: #9c6f2b;
}

.tag-done {
  background: #f8dfe4;
  color: #c25e75;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-top: 40rpx;
  color: var(--color-ink-soft);
  font-size: 26rpx;
}
