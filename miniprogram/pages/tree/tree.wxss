/* pages/tree/tree.wxss */
.tree-page {
  position: relative;
  min-height: 100vh;
  padding: 32rpx 40rpx 80rpx;
  box-sizing: border-box;
}

.page-bg {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
}

/* 场景 */
.scene {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tree-wrap {
  position: relative;
  width: 560rpx;
}

.tree {
  width: 100%;
  filter: drop-shadow(0 12rpx 28rpx rgba(120, 90, 60, 0.25));
}

/* 果子 */
.fruit {
  position: absolute;
  width: 84rpx;
  z-index: 2;
  transition: transform 0.15s ease;
}

.fruit:active {
  transform: scale(1.2);
}

/* 等你回答：金光呼吸 */
.fruit-waiting {
  animation: glow 1.6s ease-in-out infinite;
}

@keyframes glow {
  0%, 100% {
    filter: drop-shadow(0 0 6rpx rgba(255, 205, 100, 0.9));
    transform: scale(1);
  }
  50% {
    filter: drop-shadow(0 0 26rpx rgba(255, 190, 70, 1));
    transform: scale(1.12);
  }
}

/* 等 TA 回答：半透明未成熟 */
.fruit-mine {
  opacity: 0.5;
  filter: saturate(0.55);
}

/* 已成熟：鲜亮 + 落影 */
.fruit-done {
  filter: drop-shadow(0 4rpx 10rpx rgba(120, 60, 40, 0.35));
}

.plant-btn {
  margin-top: 24rpx;
  padding: 20rpx 64rpx;
}

/* 图例 */
.legend {
  display: flex;
  justify-content: center;
  gap: 28rpx;
  margin: 32rpx 0;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #7a6a5e;
  background: rgba(255, 252, 246, 0.75);
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
}

.dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.dot-waiting {
  background: var(--color-gold);
  box-shadow: 0 0 8rpx rgba(255, 190, 70, 0.9);
}

.dot-mine {
  background: #b8d8ba;
  opacity: 0.6;
}

.dot-done {
  background: #e4536a;
}

/* 列表 */
.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.list-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 26rpx 30rpx;
  background: rgba(255, 252, 246, 0.85);
  border-radius: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(120, 90, 60, 0.08);
}

.list-icon {
  width: 48rpx;
  flex-shrink: 0;
}

.list-q {
  flex: 1;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.list-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.tag-waiting {
  background: #fff3dc;
  color: #c8912a;
}

.tag-mine {
  background: #eaf6ff;
  color: #5a96c8;
}

.tag-done {
  background: #ffe9ef;
  color: var(--color-primary-deep);
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-top: 40rpx;
  color: #7a6a5e;
  font-size: 26rpx;
}
