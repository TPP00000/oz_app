/* pages/bind/bind.wxss */
.bind-page {
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.hero-house {
  width: 300rpx;
  filter: drop-shadow(0 8rpx 20rpx rgba(120, 90, 60, 0.25));
}

.hero-title {
  margin-top: 20rpx;
  font-size: 40rpx;
  font-weight: 700;
}

.hero-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: var(--color-ink-soft);
  text-align: center;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.code-box {
  background: #FBEDDC;
  border: 3rpx dashed rgba(150, 110, 70, 0.5);
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.code {
  font-size: 64rpx;
  font-weight: 800;
  letter-spacing: 16rpx;
  color: var(--color-primary-deep);
}

.code-hint {
  font-size: 24rpx;
  color: var(--color-ink-soft);
}

.code-input {
  background: #F6EBD9;
  border: 3rpx solid var(--color-line);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 34rpx;
  letter-spacing: 8rpx;
  text-align: center;
  color: var(--color-ink);
}

.divider {
  text-align: center;
  color: var(--color-ink-soft);
  font-size: 24rpx;
  margin: 36rpx 0;
  letter-spacing: 4rpx;
}
