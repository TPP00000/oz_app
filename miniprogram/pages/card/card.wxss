/* pages/card/card.wxss */
.page-bg {
  position: fixed;
  inset: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
}

.card-page {
  padding: 48rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.head-fruit {
  width: 110rpx;
}

.fruit-glow {
  animation: card-glow 1.6s ease-in-out infinite;
}

@keyframes card-glow {
  0%, 100% { filter: drop-shadow(0 0 8rpx rgba(255, 205, 100, 0.9)); }
  50% { filter: drop-shadow(0 0 28rpx rgba(255, 190, 70, 1)); }
}

.fruit-unripe {
  opacity: 0.55;
  filter: saturate(0.55);
}

.head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.head-emoji {
  font-size: 88rpx;
}

.head-title {
  font-size: 38rpx;
  font-weight: 700;
}

.head-sub {
  font-size: 26rpx;
  color: var(--color-ink-soft);
}

.input-area {
  width: 100%;
  min-height: 220rpx;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.counter {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-ink-soft);
}

/* 预设问题 */
.suggest {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.suggest-head {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--color-ink-soft);
}

.refresh {
  color: var(--color-primary-deep);
  font-weight: 600;
}

.suggest-chip {
  background: var(--color-paper);
  border: 3rpx solid var(--color-line);
  border-radius: 24rpx;
  padding: 20rpx 28rpx;
  font-size: 26rpx;
  color: var(--color-ink);
  line-height: 1.5;
  box-shadow: 0 6rpx 0 rgba(170, 130, 90, 0.18),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.7);
}

.suggest-chip:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 0 rgba(170, 130, 90, 0.15);
}

/* 问答气泡：纸片便签 */
.bubble {
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  border: 3rpx solid var(--color-line);
  box-shadow: 0 8rpx 20rpx rgba(140, 100, 60, 0.1),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.7);
}

.bubble-q {
  background: #FBEDE0;
  border-top-left-radius: 8rpx;
}

.bubble-a {
  background: #EEF2DF;
  border-top-right-radius: 8rpx;
  align-self: flex-end;
  width: 88%;
  box-sizing: border-box;
}

.bubble-label {
  font-size: 22rpx;
  color: var(--color-ink-soft);
  letter-spacing: 2rpx;
}

.bubble-text {
  font-size: 30rpx;
  line-height: 1.7;
}

.submit {
  margin-top: 16rpx;
}
