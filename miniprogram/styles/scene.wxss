/* styles/scene.wxss - 全屏横向场景页（卧室/厨房）共用样式 */

.pano-scroll {
  width: 100%;
  height: 100%;
}

.pano {
  position: relative;
}

/* 场景图柔光淡入：加载完成前显示页面底色 */
.pano-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.pano-img-show {
  opacity: 1;
}

/* 热区与柔光反馈（与主页同规范：按下才浮现） */
.hotspot {
  position: absolute;
}

.glow {
  position: absolute;
  inset: -6%;
  background: radial-gradient(
    ellipse closest-side,
    rgba(255, 240, 200, 0.5),
    rgba(255, 240, 200, 0.22) 60%,
    rgba(255, 240, 200, 0) 100%
  );
  opacity: 0;
  transition: opacity 0.35s ease;
}

.hotspot-hover .glow {
  opacity: 1;
}

/* 物件精灵：静止时与背景逐像素重合，按住时呼吸缩放 + 轮廓金色光晕（与主页同规范） */
.obj-sprite {
  position: absolute;
  transform-origin: 50% 88%;
  transition: filter 0.25s ease;
}

.sprite-pressed .obj-sprite {
  animation: sprite-breathe 1.1s ease-in-out infinite;
  filter: drop-shadow(0 0 20rpx rgba(255, 214, 130, 0.95))
    drop-shadow(0 0 6rpx rgba(255, 226, 160, 0.8));
}

@keyframes sprite-breathe {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.04);
  }
}

/* 顶部纸片：房间名（+ 可选副行） */
.room-chip {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  z-index: 40;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 14rpx 34rpx;
  background: var(--color-paper);
  border: 3rpx solid var(--color-line);
  border-radius: 999rpx;
  box-shadow: 0 6rpx 0 rgba(170, 130, 90, 0.25),
    inset 0 4rpx 0 rgba(255, 255, 255, 0.7);
}

.chip-name {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: var(--color-ink);
}
